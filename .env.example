# Copy to .env and fill in. Never commit .env.

# Required — Claude agent reasoning (Forecast/Companion/Guardian/Bridge)
ANTHROPIC_API_KEY=

# SQLite for hackathon speed
DATABASE_URL="file:./dev.db"

# Optional — sandbox-only messaging creds. Leave unset to run Companion/Circle
# Agents in demo mode: messages are drafted, Guardian-checked, and logged to
# the audit trail, but never actually sent to a third party.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=

# Field-level encryption key for SafetyPlan / message / contact content.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=
